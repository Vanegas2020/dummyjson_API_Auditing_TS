{
  "name": "dummyjson-api-auditing-ts",
  "version": "1.0.0",
  "description": "API Automation tests for dummyjson_API_Auditing_TS",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:ui": "npx playwright test --ui",
